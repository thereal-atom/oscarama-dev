---
import PageLayout from "@/layouts/PageLayout.astro";
import EventSeriesCard from "@/components/EventSeriesCard.astro";
import { eventSeriesList } from "@/data/eventSeries";
---

<PageLayout
  title="events | oscarama"
  description="bouldering, dinners, coworking, hackathons - I like to run events in London."
  ogUrl="https://oscarama.dev/events"
>
  <h1 class="text-3xl font-bold">events</h1>
  <p class="text-sm text-white/70 mt-4">
    bouldering, dinners, coworking, hackathons - I like to run events in London. sign up for some
    below :)
  </p>

  <a
    href="/events/zero-to-agent"
    class="group relative block mt-8 overflow-hidden rounded-lg border border-[#E56717]/40 bg-[linear-gradient(135deg,rgba(229,103,23,0.12),rgba(229,103,23,0.02))] p-6 transition-all hover:border-[#E56717] hover:-translate-y-0.5 hover:shadow-[0_10px_40px_-15px_rgba(229,103,23,0.5)]"
  >
    <div class="absolute -top-12 -right-12 h-40 w-40 rounded-full bg-[#E56717]/20 blur-3xl pointer-events-none">
    </div>
    <div class="relative flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-[#E56717]">
      <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-[#E56717]"></span>
      featured · sat 2 may 2026
    </div>
    <h2 class="relative mt-3 text-2xl font-bold leading-tight">
      zero <span class="text-white/40 font-normal">→</span> <span class="text-[#E56717]">agent</span>: london
    </h2>
    <p class="relative mt-2 text-sm text-white/70">
      the london stop of vercel's zero to agent global build week. ~100 cracked builders, eight
      hours, one solo agent each. bbq, ice cream & music til late.
    </p>
    <span class="relative mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[#E56717] transition-transform duration-150 group-hover:translate-x-0.5">
      see the spec & register →
    </span>
  </a>

  <div class="flex flex-col gap-6 mt-12">
    {
      eventSeriesList.map((series) => (
        <EventSeriesCard
          name={series.name}
          slug={series.slug}
          logo={series.logo}
          description={series.description}
        />
      ))
    }
  </div>

  <a
    href="/events/subscribe"
    class="group flex flex-col gap-2 mt-12 p-6 border border-dashed border-white/20 rounded-lg hover:border-[#E56717]/50 hover:bg-white/2 transition-all"
  >
    <span class="text-lg font-semibold group-hover:text-[#E56717] transition-colors">
      stay in the loop &rarr;
    </span>
    <span class="text-sm text-white/50">
      get notified about upcoming events. no spam, just good times.
    </span>
  </a>
</PageLayout>
