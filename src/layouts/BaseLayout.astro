---
import BackgroundTexture from "@/components/BackgroundTexture.astro";
import "../styles/global.css";
import Header from "@/components/Header.astro";
import Posthog from "@/components/posthog.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogUrl?: string;
}

const {
  title = "oscar | software engineer",
  description = "self-taught software engineer from London currently working @ coloop.ai (yc s21)",
  ogImage = "/og.png",
  ogUrl = "https://oscarama.dev",
} = Astro.props;

const showEventBanner = Astro.url.pathname !== "/events/zero-to-agent";
---

<!doctype html>
<html lang="en">
  <head>
    <Posthog />

    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, ogUrl).href} />
    <meta property="og:site_name" content="oscarama.dev" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={ogUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(ogImage, ogUrl).href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <!-- <BackgroundTexture /> -->
    {
      showEventBanner && (
        <a
          href="/events/zero-to-agent"
          class="group block w-full bg-[#e56717] text-[#0a0a0a] no-underline hover:no-underline"
          onclick="window.posthog?.capture('event_banner_clicked', { event: 'zero-to-agent' })"
        >
          <div class="mx-auto flex max-w-3xl items-center justify-center gap-1.5 px-3 py-2 text-[11px] sm:text-[12px] font-semibold tracking-tight whitespace-nowrap">
            <span class="inline-block h-1.5 w-1.5 shrink-0 animate-pulse rounded-full bg-[#0a0a0a]" />
            <span>zero → agent · london</span>
            <span class="opacity-70 hidden min-[420px]:inline">· sat 2 may</span>
            <span class="opacity-70 hidden sm:inline">· solo hackathon w/ vercel</span>
            <span class="ml-0.5 shrink-0 transition-transform duration-150 group-hover:translate-x-0.5">
              →
            </span>
          </div>
        </a>
      )
    }
    <div class="min-h-screen flex flex-col">
      <Header />
      <slot />
    </div>
  </body>
</html>
