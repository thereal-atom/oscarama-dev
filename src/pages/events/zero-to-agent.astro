---
import BaseLayout from "@/layouts/BaseLayout.astro";

const eventDate = new Date("2026-05-02T10:00:00+01:00");
const now = new Date();
const daysToGo = Math.max(0, Math.ceil((eventDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)));
---

<BaseLayout
  title="zero to agent: london | events | oscarama"
  description="come ship an ai agent with us. in a day. in london. then bbq, ice cream & music til late. sat 2 may 2026."
  ogUrl="https://oscarama.dev/events/zero-to-agent"
>
  <main
    class="02a relative z-[1] text-[#e8e6e1] leading-[1.65] text-[14px] antialiased [&_a]:text-[#e56717] [&_a]:no-underline [&_a:hover]:underline"
  >
    <!-- hero -->
    <section class="mx-auto max-w-[1080px] px-8 max-[560px]:px-5 pt-10 pb-[60px]">
      <div class="text-[12px] mb-8 leading-none">
        <span class="text-[#5a5854]">~/events/</span><span class="text-[#e56717]"
          >zero-to-agent-london</span
        ><span
          class="inline-block w-[7px] h-[13px] bg-[#e56717] ml-0.5 align-[-2px] animate-[02a-blink_1.1s_steps(1,end)_infinite]"
        ></span>
      </div>

      <div
        class="grid grid-cols-[1fr_340px] gap-[60px] items-start max-[920px]:grid-cols-1 max-[920px]:gap-10"
      >
        <div>
          <div
            class="inline-flex items-center gap-2.5 text-[12px] uppercase tracking-[0.18em] text-[#e56717] font-semibold mb-[18px]"
          >
            <span
              class="w-[7px] h-[7px] rounded-full bg-[#e56717] shadow-[0_0_12px_#e56717] animate-[02a-pulse_1.8s_ease-in-out_infinite]"
            ></span>registrations open · {daysToGo} {daysToGo === 1 ? "day" : "days"} to go
          </div>

          <h1
            class="text-[clamp(44px,7vw,84px)] font-extrabold leading-[0.98] tracking-[-0.035em] m-0 mb-6 max-[560px]:text-[44px]"
          >
            <span>zero</span><span class="text-[#5a5854] font-normal px-1.5">&rarr;</span><span
              class="text-[#e56717]">agent</span
            ><span
              class="text-[#e56717] animate-[02a-blink_1.1s_steps(1,end)_infinite] inline-block"
              >_</span
            >
          </h1>

          <div class="flex flex-wrap items-center gap-[14px] text-[#8a8781] text-[16px] mb-5">
            <span
              class="inline-flex items-center gap-1.5 bg-[#161615] border border-[#242321] py-[3px] px-2.5 rounded text-[13px] text-[#e8e6e1]"
              ><span class="text-[#e56717]">&#9678;</span> london</span
            >
            <span class="text-[#5a5854]">·</span>
            <span>sat 2 may 2026</span>
            <span class="text-[#5a5854]">·</span>
            <span>10:00 &mdash; late</span>
          </div>

          <p class="text-[16px] text-[#e8e6e1] max-w-[560px] m-0 mb-4">
            come ship an ai agent with us. <span class="text-[#e56717]"
              >in a day. in london. then bbq, ice cream &amp; music til late.</span
            >
          </p>

          <p class="text-[14px] text-[#8a8781] max-w-[560px] m-0">
            the london stop of vercel's
            <a
              href="https://community.vercel.com/hackathons/zero-to-agent"
              target="_blank"
              rel="noopener noreferrer">zero to agent</a
            > global build week. one glorious saturday, ~100 cracked builders, eight hours on the clock.
          </p>

          <div class="flex flex-wrap gap-3 mt-6">
            <a
              href="https://luma.com/p7pnjcu8"
              target="_blank"
              rel="noopener noreferrer"
              class="!text-[#0a0a0a] inline-block bg-[#e56717] px-[22px] py-[13px] rounded-md font-bold text-[13.5px] transition duration-150 !no-underline hover:-translate-y-[1px] hover:shadow-[0_6px_30px_-6px_rgba(229,103,23,0.6)] hover:brightness-110"
              >register on luma &rarr;</a
            >
            <a
              href="#schedule"
              class="!text-[#e8e6e1] inline-block bg-transparent px-[22px] py-[13px] rounded-md font-bold text-[13.5px] border border-[#242321] transition duration-150 !no-underline hover:-translate-y-[1px] hover:bg-[#161615]"
              >see the schedule</a
            >
          </div>

          <div class="mt-4 flex items-center gap-2 text-[12px] text-[#8a8781]">
            <span class="w-[7px] h-[7px] rounded-full bg-[#7fce7b] shadow-[0_0_10px_#7fce7b]"></span
            >approval based · hit register, i'll get back to you soon
          </div>
        </div>

        <aside
          class="w-[340px] bg-[#161615] border border-[#242321] rounded-lg shadow-[0_10px_40px_-20px_rgba(0,0,0,0.8)] sticky top-5 overflow-hidden max-[920px]:static max-[920px]:w-full max-[920px]:max-w-[420px]"
        >
          <div
            class="flex items-center gap-1.5 bg-[#1b1a18] px-[14px] py-2.5 border-b border-[#242321]"
          >
            <span class="w-[10px] h-[10px] rounded-full bg-[#ff5f57]"></span>
            <span class="w-[10px] h-[10px] rounded-full bg-[#febc2e]"></span>
            <span class="w-[10px] h-[10px] rounded-full bg-[#28c840]"></span>
            <span class="ml-2.5 text-[#8a8781] text-[11px]">~/02a-london · specs</span>
          </div>
          <div class="px-4 py-[18px] leading-[1.75] text-[12.5px]">
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="text-[#e56717]">$</span>
              <span class="text-[#8a8781]">cat</span>
              event.toml
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">when</span><span
                class="text-[#e5c07b]">"2026-05-02"</span
              >
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">doors</span><span
                class="text-[#e5c07b]">"10:00 &mdash; 22:00+"</span
              >
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">venue</span><span
                class="text-[#e5c07b]">"tbd · central london"</span
              >
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">seats</span><span
                class="text-[#7fce7b]">~100</span
              >
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">build</span><span
                class="text-[#e5c07b]">"any agent you want"</span
              >
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">stack</span><span
                class="text-[#e56717]">v0</span
              > + <span class="text-[#e56717]">vercel</span>
              <span class="text-[#5a5854] ml-2"># + anything else</span>
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="inline-block w-[80px] text-[#8a8781]">prizes</span><span
                class="text-[#7fce7b]">$6,000+ global + london</span
              >
            </div>
            <div class="h-2.5"></div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis">
              <span class="text-[#e56717]">$</span>
              <span class="text-[#8a8781]">echo</span>
              <span class="text-[#e5c07b]">"see you may 2nd"</span>
            </div>
            <div class="whitespace-nowrap overflow-hidden text-ellipsis text-[#7fce7b]"
              >&rarr; see you may 2nd</div
            >
          </div>
          <div
            class="border-t border-dashed border-[#242321] px-4 py-[14px] grid grid-cols-4 gap-2 text-center"
          >
            <div>
              <div
                class="text-[22px] font-bold text-[#e56717] tabular-nums leading-none"
                id="cd-d"
              >
                00
              </div>
              <div class="text-[10px] text-[#8a8781] uppercase tracking-[0.1em] mt-1">days</div>
            </div>
            <div>
              <div
                class="text-[22px] font-bold text-[#e56717] tabular-nums leading-none"
                id="cd-h"
              >
                00
              </div>
              <div class="text-[10px] text-[#8a8781] uppercase tracking-[0.1em] mt-1">hrs</div>
            </div>
            <div>
              <div
                class="text-[22px] font-bold text-[#e56717] tabular-nums leading-none"
                id="cd-m"
              >
                00
              </div>
              <div class="text-[10px] text-[#8a8781] uppercase tracking-[0.1em] mt-1">min</div>
            </div>
            <div>
              <div
                class="text-[22px] font-bold text-[#e56717] tabular-nums leading-none"
                id="cd-s"
              >
                00
              </div>
              <div class="text-[10px] text-[#8a8781] uppercase tracking-[0.1em] mt-1">sec</div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <!-- meta strip -->
    <section class="mx-auto max-w-[1080px] px-8 max-[560px]:px-5">
      <div
        class="grid grid-cols-3 bg-[#242321] gap-px border border-[#242321] rounded-lg overflow-hidden mb-9 max-[920px]:grid-cols-1"
      >
        <div class="bg-[#161615] px-[22px] py-5">
          <div class="text-[11px] text-[#8a8781] uppercase tracking-[0.16em] mb-2">where</div>
          <div class="text-[16px] text-[#e8e6e1] font-semibold"
            >tbd<span class="block text-[12px] text-[#8a8781] font-normal mt-1"
              >central london &mdash; announced soon</span
            ></div
          >
        </div>
        <div class="bg-[#161615] px-[22px] py-5">
          <div class="text-[11px] text-[#8a8781] uppercase tracking-[0.16em] mb-2">who</div>
          <div class="text-[16px] text-[#e8e6e1] font-semibold"
            >~100 builders<span class="block text-[12px] text-[#8a8781] font-normal mt-1"
              >engineers, designers, founders</span
            ></div
          >
        </div>
        <div class="bg-[#161615] px-[22px] py-5">
          <div class="text-[11px] text-[#8a8781] uppercase tracking-[0.16em] mb-2">you get</div>
          <div class="text-[16px] text-[#e8e6e1] font-semibold"
            >v0 + vercel credits<span class="block text-[12px] text-[#8a8781] font-normal mt-1"
              >plus the full sponsor stack</span
            ></div
          >
        </div>
      </div>
    </section>

    <!-- TODO: link tracks, judging & submission out to a dedicated page with full details -->
    <!-- tracks -->
    <section
      class="mx-auto max-w-[1080px] px-8 max-[560px]:px-5 py-14 border-t border-dashed border-[#1f1e1c]"
    >
      <div
        class="flex justify-between items-baseline flex-wrap gap-4 mb-7 max-[920px]:[&>.kicker]:text-left"
      >
        <div>
          <div
            class="text-[#e56717] text-[12px] uppercase tracking-[0.18em] font-semibold mb-2.5"
            >01 / what you'll build</div
          >
          <h2
            class="text-[clamp(28px,3.5vw,40px)] font-bold tracking-[-0.015em] leading-[1.1] m-0"
            >agents. <span class="text-[#e56717]">any agents.</span></h2
          >
        </div>
        <div
          class="kicker text-[13.5px] text-[#8a8781] max-w-[480px] text-right max-[920px]:text-left"
        >
          three tracks, each backed by a real shipping stack from vercel. pick one, or freestyle
          &mdash; just ship something cool by 19:00.
        </div>
      </div>

      <div
        class="grid grid-cols-3 gap-3.5 max-[920px]:grid-cols-1 [&>*]:bg-[#161615] [&>*]:border [&>*]:border-[#242321] [&>*]:rounded-lg [&>*]:px-5 [&>*]:pt-[22px] [&>*]:pb-6 [&>*]:transition [&>*]:duration-150 [&>*:hover]:-translate-y-0.5 [&>*:hover]:border-[#3a3834]"
      >
        <div>
          <div
            class="text-[44px] font-extrabold text-[#e56717] opacity-[0.18] tracking-[-0.04em] leading-none mb-2.5"
            >01</div
          >
          <div class="text-[10px] text-[#e56717] uppercase tracking-[0.2em] mb-2.5">track</div>
          <div class="text-[15px] font-bold leading-[1.3] mb-2">vercel workflow (wdk)</div>
          <div class="text-[12.5px] text-[#8a8781] leading-[1.55]"
            >long-running, durable async agents that survive crashes, resume after deploys, and pause for minutes or months.</div
          >
        </div>
        <div>
          <div
            class="text-[44px] font-extrabold text-[#e56717] opacity-[0.18] tracking-[-0.04em] leading-none mb-2.5"
            >02</div
          >
          <div class="text-[10px] text-[#e56717] uppercase tracking-[0.2em] mb-2.5">track</div>
          <div class="text-[15px] font-bold leading-[1.3] mb-2">v0 + mcps</div>
          <div class="text-[12.5px] text-[#8a8781] leading-[1.55]"
            >use v0 to rapidly build an ai app or agent that connects to at least one mcp server.</div
          >
        </div>
        <div>
          <div
            class="text-[44px] font-extrabold text-[#e56717] opacity-[0.18] tracking-[-0.04em] leading-none mb-2.5"
            >03</div
          >
          <div class="text-[10px] text-[#e56717] uppercase tracking-[0.2em] mb-2.5">track</div>
          <div class="text-[15px] font-bold leading-[1.3] mb-2">chatsdk agents</div>
          <div class="text-[12.5px] text-[#8a8781] leading-[1.55]"
            >ai sdk + ai gateway + chatsdk agents that interface across slack, discord, teams, github, and more.</div
          >
        </div>
      </div>

      <a
        href="https://vercel.notion.site/02agentresources"
        target="_blank"
        rel="noopener noreferrer"
        class="!text-[#e8e6e1] !no-underline hover:!no-underline mt-5 flex items-center justify-between gap-4 px-5 py-4 border border-[#e56717]/40 rounded-lg bg-[linear-gradient(140deg,rgba(229,103,23,0.08),transparent)] transition duration-150 hover:border-[#e56717] hover:-translate-y-0.5 max-[560px]:flex-col max-[560px]:items-start"
      >
        <div>
          <div class="text-[10px] text-[#e56717] uppercase tracking-[0.2em] mb-1">// resources</div>
          <div class="text-[14px] font-bold text-[#e8e6e1]"
            >full track docs, quickstarts & sdk links</div
          >
          <div class="text-[12px] text-[#8a8781] mt-0.5"
            >vercel's official zero to agent resource hub &mdash; everything you need to ship</div
          >
        </div>
        <div class="text-[12px] text-[#e56717] font-semibold whitespace-nowrap"
          >vercel.notion.site/02agentresources &rarr;</div
        >
      </a>
    </section>

    <!-- schedule -->
    <section
      id="schedule"
      class="mx-auto max-w-[1080px] px-8 max-[560px]:px-5 py-14 border-t border-dashed border-[#1f1e1c]"
    >
      <div class="flex justify-between items-baseline flex-wrap gap-4 mb-7">
        <div>
          <div
            class="text-[#e56717] text-[12px] uppercase tracking-[0.18em] font-semibold mb-2.5"
            >02 / the day</div
          >
          <h2
            class="text-[clamp(28px,3.5vw,40px)] font-bold tracking-[-0.015em] leading-[1.1] m-0"
            >10:00 &rarr; <span class="text-[#e56717]">late.</span></h2
          >
        </div>
        <div class="text-[13.5px] text-[#8a8781] max-w-[480px] text-right max-[920px]:text-left">
          arrive from 10am. hacking kicks off around 11:30, wraps around 8pm. stick around for the
          afterparty.
        </div>
      </div>

      <div class="grid grid-cols-[140px_1fr] max-[560px]:grid-cols-[90px_1fr]">
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >10:00</div
          >
          <div class="pl-7 py-5 max-[560px]:pl-[18px] max-[560px]:py-4">
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">arrival & check in</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">coffee / pastries / say hi</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >11:00</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">intro</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5"
              >vercel + sponsors + me · format, judging, info</div
            >
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >11:30</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[17px] font-semibold text-[#e56717]"
              >hacking starts &#129489;&zwj;&#128187;</div
            >
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">8 hours on the clock</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >13:00</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">lunch</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">on us</div>
          </div>
        </div>
        <div class="contents 02a-row 02a-row-dim">
          <div
            class="02a-t relative text-[17px] font-normal text-[#5a5854] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:pr-3.5 max-[560px]:py-4"
            >16:00</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-normal text-[#8a8781]">snack + caffeine refresh</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >19:30</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">tools down · top 6 demos</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">5 min each on the main stage</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >19:30</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">fireside chat</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">while judges do their thing</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >20:00</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[17px] font-semibold text-[#e56717]">winners &#127942;</div>
          </div>
        </div>
        <div class="contents 02a-row">
          <div
            class="02a-t relative text-[22px] font-bold text-[#e56717] tabular-nums tracking-[-0.01em] pr-6 py-5 text-right border-r border-[#242321] max-[560px]:text-[16px] max-[560px]:pr-3.5 max-[560px]:py-4"
            >20:00+</div
          >
          <div
            class="pl-7 py-5 border-t border-dashed border-[#1f1e1c] max-[560px]:pl-[18px] max-[560px]:py-4"
          >
            <div class="text-[15.5px] font-semibold text-[#e8e6e1]">afterparty</div>
            <div class="text-[12.5px] text-[#8a8781] mt-0.5">bbq · drinks · ice cream &#127846;</div>
          </div>
        </div>
      </div>
    </section>

    <!-- judging -->
    <section
      class="mx-auto max-w-[1080px] px-8 max-[560px]:px-5 py-14 border-t border-dashed border-[#1f1e1c]"
    >
      <div class="flex justify-between items-baseline flex-wrap gap-4 mb-7">
        <div>
          <div
            class="text-[#e56717] text-[12px] uppercase tracking-[0.18em] font-semibold mb-2.5"
            >03 / judging & submission</div
